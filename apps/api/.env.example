# Server
PORT=3000
HOST=0.0.0.0

# Comma-separated frontend origins allowed by CORS.
CORS_ORIGIN=http://localhost:3001

# PostgreSQL connection used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fluxcred?schema=public"

# Required. Use a strong secret outside local development.
JWT_SECRET="change-me"

# Frontend URL used to generate verification and password reset links.
APP_WEB_URL=http://localhost:3001

# Local development: prints verification/reset links in the API console.
# Real email: set MAIL_DELIVERY_MODE=resend and provide RESEND_API_KEY.
MAIL_DELIVERY_MODE=console
MAIL_FROM="FluxCred <no-reply@example.com>"

# Optional: enables real email delivery through Resend.
# RESEND_API_KEY=

# Optional: disable API docs endpoints when set to false.
# ENABLE_API_DOCS=false

# Optional: disable demo connections when set to false.
# ENABLE_DEMO_CONNECTIONS=false
