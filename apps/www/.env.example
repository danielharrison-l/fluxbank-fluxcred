# Vite dev/preview server.
PORT=3001
HOST=0.0.0.0

# API base URL used by the browser app.
# In the production Docker image this is also injected at container startup
# through /runtime-config.js, so set it in the hosting environment as well.
VITE_API_URL=http://localhost:3000

# Playwright base URL for e2e tests.
E2E_APP_BASE_URL=http://localhost:3001
